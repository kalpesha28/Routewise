{
  "expo": {
    "name": "RouteWise",
    "slug": "routewise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "routewise",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.routewise.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RouteWise needs your location to optimize delivery routes.",
        "NSLocationAlwaysUsageDescription": "RouteWise needs your location to track deliveries.",
        "NSCameraUsageDescription": "RouteWise needs camera access to capture proof of delivery."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.routewise.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RouteWise needs location to optimize your delivery routes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "RouteWise needs camera to capture proof of delivery."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70154e3f-50c6-4488-a173-3e2209ac0d4d"
      }
    }
  }
}
